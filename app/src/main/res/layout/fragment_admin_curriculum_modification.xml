<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:text="Curriculum Fields"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Grade -->
        <TextView
            style="@style/FormLabel"
            android:text="Grade"/>

        <Spinner
            android:id="@+id/grade_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/shared_bg_input_rounded"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Curriculum Name -->
        <TextView
            style="@style/FormLabel"
            android:text="Curriculum Name"/>

        <EditText
            android:id="@+id/curriculum_name_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/shared_bg_input_rounded"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Book References -->
        <TextView
            style="@style/FormLabel"
            android:text="Book References"/>

        <EditText
            android:id="@+id/book_references_edit"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:background="@drawable/shared_bg_input_rounded"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Resource Link -->
        <TextView
            style="@style/FormLabel"
            android:text="Resource Link"/>

        <EditText
            android:id="@+id/link_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="https://..."
            android:inputType="textUri"
            android:background="@drawable/shared_bg_input_rounded"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="24dp"/>

        <!-- Save -->
        <Button
            android:id="@+id/save_curriculum_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Save Curriculum"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/accent_blue"/>

    </LinearLayout>

</ScrollView>