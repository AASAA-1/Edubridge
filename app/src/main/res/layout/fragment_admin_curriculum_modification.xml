<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Curriculum Fields"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="24dp"/>

        <!-- Class ID -->
        <TextView
            style="@style/FormLabel"
            android:text="Class ID"/>

        <EditText
            android:id="@+id/class_id_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/shared_bg_input_rounded"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Curriculum Name -->
        <TextView
            style="@style/FormLabel"
            android:text="Curriculum Name"/>

        <EditText
            android:id="@+id/curriculum_name_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/shared_bg_input_rounded"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Book References -->
        <TextView
            style="@style/FormLabel"
            android:text="Book References"/>

        <EditText
            android:id="@+id/book_references_edit"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:background="@drawable/shared_bg_input_rounded"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Files -->
        <TextView
            style="@style/FormLabel"
            android:text="Files"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/upload_file_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_upload"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Upload File"
                android:tint="@color/accent_blue"/>

            <ImageButton
                android:id="@+id/view_files_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:src="@android:drawable/ic_menu_view"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="View Files"
                android:tint="@color/accent_blue"/>

        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/save_curriculum_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Save Curriculum"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/accent_blue"/>

    </LinearLayout>

</ScrollView>