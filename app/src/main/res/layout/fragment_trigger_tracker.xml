<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorBackgroundCustom">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorBackgroundCustom"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/trigger_tracker_title"
        app:titleTextColor="?attr/colorSecondaryCustom" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="@dimen/card_padding"
        android:paddingRight="@dimen/card_padding"
        android:paddingBottom="@dimen/margin_large"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Class Selection -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_standard"
                android:layout_marginBottom="@dimen/margin_standard"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/card_elevation_low"
                app:cardBackgroundColor="?attr/colorElementBackgroundCustom">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_select_class"
                        android:textColor="?attr/colorSecondaryCustom"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/margin_small" />

                    <Spinner
                        android:id="@+id/spinner_class"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:background="@drawable/shared_bg_input_rounded"
                        android:paddingLeft="@dimen/margin_standard"
                        android:paddingRight="@dimen/margin_standard" />

                    <TextView
                        android:id="@+id/tv_class_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_small"
                        android:textColor="?attr/colorErrorCustom"
                        android:textSize="@dimen/text_small"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Student Selection -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_standard"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/card_elevation_low"
                app:cardBackgroundColor="?attr/colorElementBackgroundCustom">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_select_student"
                        android:textColor="?attr/colorSecondaryCustom"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/margin_small" />

                    <Spinner
                        android:id="@+id/spinner_student"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:background="@drawable/shared_bg_input_rounded"
                        android:paddingLeft="@dimen/margin_standard"
                        android:paddingRight="@dimen/margin_standard" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Incidents Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_standard"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/card_elevation_low"
                app:cardBackgroundColor="?attr/colorElementBackgroundCustom">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <!-- Header row: label + Log button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/margin_standard">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_incidents"
                            android:textColor="?attr/colorSecondaryCustom"
                            android:textSize="@dimen/text_medium"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_log_incident"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_log_incident"
                            android:textSize="@dimen/text_xs"
                            app:backgroundTint="?attr/colorAccentCustom"
                            app:cornerRadius="@dimen/margin_small" />

                    </LinearLayout>

                    <!-- Empty state -->
                    <TextView
                        android:id="@+id/tv_empty_incidents"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_incidents"
                        android:textColor="?attr/colorSecondaryCustom"
                        android:textSize="@dimen/text_small"
                        android:gravity="center"
                        android:paddingTop="@dimen/margin_standard"
                        android:paddingBottom="@dimen/margin_standard"
                        android:visibility="gone" />

                    <!-- Incidents list -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_incidents"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Analyze Patterns Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_analyze"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="@dimen/margin_standard"
                android:text="@string/btn_analyze_patterns"
                android:textColor="@color/white"
                app:backgroundTint="?attr/colorAccentCustom"
                app:cornerRadius="@dimen/margin_small" />

            <!-- AI Result Card (hidden until analysis runs) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_ai_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_large"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/card_elevation_low"
                app:cardBackgroundColor="?attr/colorElementBackgroundCustom">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_analysis_title"
                        android:textColor="?attr/colorSecondaryCustom"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/margin_standard" />

                    <ProgressBar
                        android:id="@+id/pb_analyzing"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_analysis_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
