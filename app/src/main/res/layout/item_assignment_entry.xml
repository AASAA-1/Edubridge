<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/assignment_item_padding_horizontal"
    android:paddingTop="@dimen/assignment_item_padding_top"
    android:paddingEnd="@dimen/assignment_item_padding_horizontal"
    android:paddingBottom="@dimen/assignment_item_padding_bottom">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/colorTextCustom"
            android:textSize="@dimen/assignment_item_title_text_size"
            tools:text="Math Homework 3 : Fractions" />

        <ImageView
            android:id="@+id/ivFileIcon"
            android:layout_width="@dimen/assignment_item_file_icon_size"
            android:layout_height="@dimen/assignment_item_file_icon_size"
            android:padding="@dimen/assignment_item_file_icon_padding"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_file_attachment" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/assignment_item_meta_margin"
        android:textColor="?attr/colorSecondaryCustom"
        android:textSize="@dimen/assignment_item_meta_text_size"
        tools:text="Uploaded By: Mr Ahmed On 8 Jun 2025" />

    <TextView
        android:id="@+id/tvDueDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/assignment_item_due_date_margin"
        android:textColor="?attr/colorErrorCustom"
        android:textSize="@dimen/assignment_item_meta_text_size"
        tools:text="Due Date: Jun 10th" />

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:layout_marginTop="@dimen/assignment_item_divider_margin"
        android:background="?attr/colorBorderCustom" />
</LinearLayout>