<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/margin_standard"
    android:layout_marginVertical="@dimen/margin_xs"
    app:cardCornerRadius="@dimen/card_corner_radius_large"
    app:cardElevation="@dimen/card_elevation_low"
    app:cardBackgroundColor="?attr/colorElementBackgroundCustom">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/card_inner_padding">

        <!-- Unread indicator dot -->
        <View
            android:id="@+id/unreadDot"
            android:layout_width="@dimen/notification_unread_dot_size"
            android:layout_height="@dimen/notification_unread_dot_size"
            android:background="@drawable/circle_dot"
            app:layout_constraintTop_toTopOf="@id/tvTitle"
            app:layout_constraintBottom_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Notification title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_standard"
            android:layout_marginEnd="@dimen/margin_small"
            android:textColor="?attr/colorTextCustom"
            android:textSize="@dimen/text_small"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/unreadDot"
            app:layout_constraintEnd_toStartOf="@id/tvTime" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorAccentCustom"
            android:textSize="@dimen/text_xs"
            app:layout_constraintTop_toTopOf="@id/tvTitle"
            app:layout_constraintBottom_toBottomOf="@id/tvTitle"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Notification body / preview -->
        <TextView
            android:id="@+id/tvBody"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_xs"
            android:textColor="?attr/colorAccentCustom"
            android:textSize="@dimen/text_caption"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="@id/tvTitle"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Mark as read button (hidden when already read) -->
        <TextView
            android:id="@+id/btnMarkRead"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:text="@string/mark_as_read"
            android:textColor="?attr/colorAccentCustom"
            android:textSize="@dimen/text_caption"
            android:paddingVertical="@dimen/margin_tiny"
            android:paddingHorizontal="@dimen/margin_small"
            app:layout_constraintTop_toBottomOf="@id/tvBody"
            app:layout_constraintStart_toStartOf="@id/tvBody"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Delete button -->
        <TextView
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:text="@string/delete_notification"
            android:textColor="#E53935"
            android:textSize="@dimen/text_caption"
            android:paddingVertical="@dimen/margin_tiny"
            android:paddingHorizontal="@dimen/margin_small"
            app:layout_constraintTop_toBottomOf="@id/tvBody"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
