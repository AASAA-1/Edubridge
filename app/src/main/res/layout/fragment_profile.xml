<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="16dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:text="User Profile"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            style="@style/FormLabel"
            android:text="Full Name"/>

        <EditText
            android:id="@+id/full_name_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="textPersonName"
            android:background="@drawable/shared_bg_input_rounded"
            android:layout_marginBottom="16dp"/>

        <TextView
            style="@style/FormLabel"
            android:text="Email"/>

        <EditText
            android:id="@+id/email_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="textEmailAddress"
            android:background="@drawable/shared_bg_input_rounded"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/password_label"
            style="@style/FormLabel"
            android:text="Password"/>

        <EditText
            android:id="@+id/password_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="textPassword"
            android:background="@drawable/shared_bg_input_rounded"
            android:layout_marginBottom="16dp"/>

        <TextView
            style="@style/FormLabel"
            android:text="Phone"/>

        <EditText
            android:id="@+id/phone_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="phone"
            android:background="@drawable/shared_bg_input_rounded"
            android:layout_marginBottom="16dp"/>

        <TextView
            style="@style/FormLabel"
            android:text="Role"/>

        <Spinner
            android:id="@+id/role_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/shared_bg_input_rounded"
            android:layout_marginBottom="16dp"/>

        <TextView
            style="@style/FormLabel"
            android:text="Date of Birth"/>

        <EditText
            android:id="@+id/dob_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="YYYY-MM-DD"
            android:background="@drawable/shared_bg_input_rounded"
            android:layout_marginBottom="16dp"/>

        <!-- Parent-only student section -->

        <LinearLayout
            android:id="@+id/student_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:text="Students"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:id="@+id/student_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <Button
                android:id="@+id/add_student_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Add Student"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <TextView
            style="@style/FormLabel"
            android:text="Notes"/>

        <EditText
            android:id="@+id/notes_edit"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/shared_bg_input_rounded"
            android:layout_marginBottom="24dp"
            android:gravity="top"
            android:inputType="textMultiLine"/>

        <Button
            android:id="@+id/save_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Save"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/accent_blue"/>

    </LinearLayout>

</ScrollView>