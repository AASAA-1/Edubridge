<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorBackgroundCustom">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorElementBackgroundCustom"
        app:title="@string/games_report_title"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:titleTextColor="?attr/colorTextCustom"
        android:contentDescription="@string/games_report_title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="?attr/colorElementBackgroundCustom">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_selected_child"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="?attr/colorTextCustom"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_change_child"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/games_report_change_child"
                        android:textColor="?attr/colorElementBackgroundCustom"
                        android:textSize="12sp"
                        app:backgroundTint="?attr/colorAccentCustom"
                        app:cornerRadius="8dp"
                        android:contentDescription="@string/games_report_change_child" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_empty_report"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/games_report_no_sessions"
                android:textColor="?attr/colorTextCustom"
                android:textSize="16sp"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/report_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
