<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackgroundCustom">

    <!-- Header: Back + Contact Name -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/chat_header_padding"
        android:background="?attr/colorElementBackgroundCustom"
        android:elevation="@dimen/card_elevation_low"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="@dimen/chat_header_back_button_size"
            android:layout_height="@dimen/chat_header_back_button_size"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="?attr/colorAccentCustom"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/contact_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/contact_avatar_text_size"
            android:textStyle="bold"
            android:textColor="?attr/colorAccentCustom"
            android:layout_marginStart="@dimen/chat_header_title_margin_start" />
    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/input_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Upload progress bar -->
    <ProgressBar
        android:id="@+id/upload_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="@dimen/chat_upload_progress_height"
        android:visibility="gone"
        android:max="100"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Messages list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="@dimen/chat_messages_padding"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/input_bar" />

    <!-- Input bar with attachment options -->
    <LinearLayout
        android:id="@+id/input_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/chat_input_padding"
        android:background="?attr/colorElementBackgroundCustom"
        android:elevation="@dimen/card_elevation"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Attachment options bar (hidden by default) -->
        <LinearLayout
            android:id="@+id/attachment_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/chat_attachment_option_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/margin_tiny">

            <ImageView
                android:id="@+id/btn_image"
                android:layout_width="@dimen/chat_attachment_icon_size"
                android:layout_height="@dimen/chat_attachment_icon_size"
                android:src="@android:drawable/ic_menu_gallery"
                android:padding="@dimen/chat_input_padding"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_send_image" />

            <ImageView
                android:id="@+id/btn_file"
                android:layout_width="@dimen/chat_attachment_icon_size"
                android:layout_height="@dimen/chat_attachment_icon_size"
                android:src="@android:drawable/ic_menu_upload"
                android:padding="@dimen/chat_input_padding"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_send_file" />

            <ImageView
                android:id="@+id/btn_voice"
                android:layout_width="@dimen/chat_attachment_icon_size"
                android:layout_height="@dimen/chat_attachment_icon_size"
                android:src="@android:drawable/ic_btn_speak_now"
                android:padding="@dimen/chat_input_padding"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_record_voice" />
        </LinearLayout>

        <!-- Text input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_attach"
                android:layout_width="@dimen/chat_input_icon_size"
                android:layout_height="@dimen/chat_input_icon_size"
                android:src="@android:drawable/ic_menu_add"
                android:padding="@dimen/chat_input_padding"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_attach" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/type_message_hint"
                android:maxLines="4"
                android:inputType="textMultiLine"
                android:background="@android:color/transparent"
                android:padding="@dimen/chat_input_text_padding" />

            <ImageView
                android:id="@+id/btn_send"
                android:layout_width="@dimen/chat_input_icon_size"
                android:layout_height="@dimen/chat_input_icon_size"
                android:src="@android:drawable/ic_menu_send"
                app:tint="?attr/colorAccentCustom"
                android:padding="@dimen/chat_input_padding"
                android:clickable="true"
                android:focusable="true"
                android:enabled="false"
                android:alpha="0.3"
                android:contentDescription="@string/cd_send" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>